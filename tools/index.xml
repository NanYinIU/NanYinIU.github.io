    <item>
      <title>使用idea对spring boot应用进行热部署</title>
      <link>https://nanyiniu.github.io/tools/%E4%BD%BF%E7%94%A8idea%E8%AE%BE%E7%BD%AEspringboot%E7%83%AD%E9%83%A8%E7%BD%B2/</link>
